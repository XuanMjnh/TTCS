{
  "img_size": 224,
  "batch_size": 32,
  "seed": 42,
  "architecture": "efficientnetb0",
  "dropout_rate": 0.3,
  "head_units": 256,
  "stage1_epochs": 8,
  "stage2_epochs": 12,
  "learning_rate_stage1": 0.001,
  "learning_rate_stage2": 1e-05,
  "fine_tune_layers": 40,
  "use_class_weights": true,
  "early_stopping_patience": 5,
  "reduce_lr_patience": 2,
  "weight_decay": 1e-05,
  "top_k": 5,
  "normalization_type": "none",
  "model_version": "multi_crop_disease_v1.0.0",
  "labels_version": "labels_v1",
  "taxonomy_version": "taxonomy_v1",
  "preprocessing_version": "preprocess_v1",
  "enable_quality_gate": true,
  "min_sharpness": 80.0,
  "min_brightness": 35.0,
  "max_brightness": 230.0,
  "default_confidence_threshold": null,
  "default_uncertainty_margin": null,
  "output_activation": "softmax",
  "augmentation": {
    "RandomFlip": "horizontal",
    "RandomRotation": 0.05,
    "RandomTranslation": 0.05,
    "RandomZoom": 0.08,
    "RandomContrast": 0.08,
    "GaussianNoiseStd": 0.01,
    "Notes": "Light leaf-safe augmentation. Avoid strong color shift, heavy blur, or small crop that removes disease region."
  }
}